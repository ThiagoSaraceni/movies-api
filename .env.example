# =============================================================================
# Cine Review API — variáveis de ambiente
# =============================================================================
# 1. cp .env.example .env
# 2. Preencha as seções obrigatórias abaixo
# 3. npm install && npm run start:dev
#
# Banco Supabase: Settings → Database → Connect → Transaction (pooler, porta 6543)
# Guia completo: DEPLOY.md
# =============================================================================

# --- App ---
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3001

# --- Auth (obrigatório) ---
# Gere com: openssl rand -base64 32
JWT_SECRET=
JWT_REFRESH_SECRET=

# --- Banco: Supabase (produção / WSL) ---
# Use o pooler do painel Connect — NÃO use db.[ref].supabase.co no WSL
DB_HOST=aws-0-[regiao].pooler.supabase.com
DB_PORT=6543
DB_USER=postgres.[seu-ref]
DB_PASSWORD=
DB_NAME=postgres
DB_SSL=true

# --- Banco: local com Docker (alternativa) ---
# Comente a seção Supabase acima e descomente:
# DB_HOST=localhost
# DB_PORT=8888
# DB_USER=pgadmin
# DB_PASSWORD=pgadmin
# DB_NAME=movies_db

# --- Opcional ---
# DATABASE_URL=          # alternativa às variáveis DB_* (mesmos dados do pooler)
# DB_LOGGING=false
